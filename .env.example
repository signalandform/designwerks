NEXT_PUBLIC_SUPABASE_URL=
# Publishable (recommended) or legacy anon JWT — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required for saving inquiries + homepage overrides (keep server-only)
SUPABASE_SERVICE_ROLE_KEY=

# Logical site id for this deployment (e.g. designwerks). Admins must have a row in
# public.dw_site_admins (site_slug, user_id) matching this value — other apps on the same DB use a different slug.
SITE_SLUG=
